# Copy this file to .env and fill in the keys for the provider(s) you use.
# None of these are required to run the demo: with no keys set, the agent
# automatically falls back to local TF-IDF embeddings + an extractive
# (non-LLM) response generator, so the full pipeline still runs end-to-end.

# Which LLM provider to use for response generation + persona tie-breaking.
# One of: auto | openai | anthropic | ollama | none
LLM_PROVIDER=auto

# --- OpenAI ---
# Used for both chat completion and text-embedding-3-small embeddings if set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Ollama (local LLM) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
